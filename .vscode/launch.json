{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Trap distr builder",
            "type": "debugpy",
            "request": "launch",
            "module": "gex.trap_distr_builder",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Sim algo check",
            "type": "debugpy",
            "request": "launch",
            "module": "gex.sim_algo_check",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}